# Production Environment Variables

# Database
# Will be set by Render automatically
DATABASE_URL=postgresql+psycopg://user:password@render-db:5432/ethara

# CORS Origins - update with your deployed URLs
BACKEND_CORS_ORIGINS=https://ethara.vercel.app,https://ethara-frontend.onrender.com

# API Base URL for Frontend - set in Vercel
VITE_API_BASE_URL=https://ethara-backend.onrender.com
